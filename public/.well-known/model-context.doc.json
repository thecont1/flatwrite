          },
          "warnings": {
            "description": "Non-fatal warnings.",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "ok",
          "documentId",
          "format"
        ],
        "additionalProperties": false,
        "description": "Result of exporting the document as PDF (via browser print dialog)."
      },
      "annotations": {
        "readOnlyHint": false
      },
      "displayHints": {
