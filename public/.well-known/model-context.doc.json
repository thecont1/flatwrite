          },
          "nextSuggestedTool": {
            "type": "string",
            "description": "Suggested next tool to call (e.g. render_markdown_preview)."
          }
        }
      },
      "annotations": {
        "readOnlyHint": false
      },
      "displayHints": {
        "inputFieldAliases": {}
      }
    },
    {
      "name": "list_recent_documents",
